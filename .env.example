# Copy to .env and fill in. Never commit the filled-in .env file - it
# contains credentials.
#
# Second mailbox? Copy the whole project directory instead of renaming this
# file to .env.<name> - see docs/setup.md "Mehrere Postfächer" for why.

# --- host paths used by docker-compose.yml -----------------------------
CONFIG_PATH=./config/config.toml
DATA_PATH=./data
# Host directory where the NAS share (SMB/NFS) is already mounted, e.g. via
# fstab or a systemd .mount unit. LevelKeeper never mounts/unmounts this -
# see README "NAS-Mount" section.
NAS_ARCHIVE_PATH=/mnt/nas/mail-archive

# --- everything below can instead live in config.toml -------------------
# ENV vars always win over the config file.

LEVELKEEPER_IMAP_HOST=imap.strato.de
LEVELKEEPER_IMAP_PORT=993
LEVELKEEPER_IMAP_USER=user@example.com
LEVELKEEPER_IMAP_PASSWORD=changeme

LEVELKEEPER_SMTP_HOST=smtp.strato.de
LEVELKEEPER_SMTP_PORT=465
LEVELKEEPER_SMTP_USER=user@example.com
LEVELKEEPER_SMTP_PASSWORD=changeme
LEVELKEEPER_SMTP_FROM_ADDR=user@example.com

LEVELKEEPER_QUOTA=2GB
LEVELKEEPER_TRIGGER=80%
LEVELKEEPER_TARGET=70%

LEVELKEEPER_ARCHIVE_ROOT=/archive
LEVELKEEPER_EXCLUDE_FOLDERS=Trash,Junk,Drafts
LEVELKEEPER_MAX_MESSAGE_SIZE=25MB
LEVELKEEPER_MOUNT_MARKER=.levelkeeper_mounted

LEVELKEEPER_REPORT_RECIPIENTS=user@example.com
LEVELKEEPER_ERROR_RECIPIENTS=user@example.com

LEVELKEEPER_LOG_LEVEL=INFO
LEVELKEEPER_LOG_FORMAT=text
LEVELKEEPER_DRY_RUN=true
# Empty = run once and exit (drive scheduling via host cron instead).
LEVELKEEPER_RUN_INTERVAL=1h
LEVELKEEPER_STATE_PATH=/data/state.json
LEVELKEEPER_LOCK_FILE=/data/levelkeeper.lock
